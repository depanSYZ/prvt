# ── Cloudflare Turnstile ─────────────────────────────────────────────────────
# Dapatkan di: https://dash.cloudflare.com → Turnstile → Add site
# NEXT_PUBLIC_ = aman di browser (siteKey)
# Tanpa NEXT_PUBLIC_ = hanya di server (secretKey → taruh di lib/config.ts)

NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...    # ← Site Key dari Cloudflare
# Secret Key tetap di lib/config.ts (TURNSTILE.secretKey), jangan taruh di sini
